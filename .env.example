# 대진대학교 AI캠퍼스 — 환경변수 샘플
# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요. (.env.local 은 git 에 올리지 않습니다)

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 배포 사이트 URL (로컬은 http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 참고: service_role 키는 클라이언트/Vercel 공개 환경변수에 절대 넣지 않습니다.
#       이 앱은 Supabase anon key + RLS 정책으로 동작합니다.
